{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(python:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pip:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)",
      "Bash(git push origin main)",
      "Bash(git push origin :*)",
      "Bash(git push --tags)",
      "Bash(git push origin --tags)",
      "Bash(mkdocs:*)",
      "Bash(pre-commit:*)"
    ],
    "ask": [
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(rm:*)",
      "Bash(del:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)"
    ]
  },
  "env": {
    "AUTOFILL_PROJECT": "auto-fill-capdon",
    "GITHUB_REPO": "VietAnh954/Project_Autofill_capDon"
  },
  "context": {
    "alwaysIncludeFiles": [
      "CLAUDE.md",
      "docs/TODO.md",
      "docs/TASKS.md"
    ]
  }
}