# ============================================================
# auto-fill-capdon — Environment configuration
# Copy file này thành `.env` và điền giá trị thật.
# KHÔNG commit `.env` lên git.
# ============================================================

# --- File paths ---
MASTER_FILE_PATH=C:\Users\ADMIN\OneDrive\Company\Project_Autofill_capDon\data\master\master.xlsx
DATA_ROOT=C:\Users\ADMIN\OneDrive\Company\Project_Autofill_capDon\data
LOG_DIR=C:\Users\ADMIN\OneDrive\Company\Project_Autofill_capDon\logs

# --- Outlook ---
# Tên profile Outlook (xem trong Control Panel → Mail → Show Profiles)
OUTLOOK_PROFILE=Outlook
# Tên folder cần đọc (mặc định Inbox). Có thể subfolder: "Inbox\\CấpĐơn"
OUTLOOK_INBOX_FOLDER=Inbox
# Folder để move mail đã xử lý (sẽ tự tạo nếu chưa có)
OUTLOOK_PROCESSED_FOLDER=Inbox\Processed

# --- Sender allowlist (cách nhau dấu phẩy) ---
SENDER_ALLOWLIST=dailya@pti.com.vn,dailyb@pti.com.vn,daily.dulich@example.com

# --- Sender → sheet hint (tùy chọn, ưu tiên cao hơn subject) ---
SENDER_DULICH=daily.dulich@example.com
SENDER_OTO=daily.oto@example.com
SENDER_XEMAY=daily.xemay@example.com
SENDER_SUCKHOE=daily.sk@example.com
SENDER_BHYT=daily.bhyt@example.com
SENDER_HSSV=daily.hssv@example.com

# --- Subject filter ---
# Regex (Python). Mặc định: bất kỳ mail nào subject chứa "cấp đơn" (không phân biệt hoa thường)
SUBJECT_PATTERN=(?i)c[aâấ]p\s*[đd][oơô]n|phi[eếề]u\s*c[aâấ]p

# --- Behavior flags ---
DRY_RUN=false
BACKUP_EVERY_RUN=false
MAX_ATTACHMENT_MB=20
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=10

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON_PATH=logs/app.jsonl

# --- Future (Phase 3) ---
# DATABASE_URL=sqlite:///data/db/autofill.db
